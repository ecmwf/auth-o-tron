{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "const": "1.0.0"
        }
      },
      "$ref": "#/$defs/ConfigV1",
      "required": [
        "version"
      ]
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "const": "2.0.0"
        }
      },
      "$ref": "#/$defs/ConfigV2",
      "required": [
        "version"
      ]
    }
  ],
  "$defs": {
    "AugmenterConfig": {
      "description": "Configuration options for augmenters (e.g. an LDAP roles augmenter).",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ldap"
            }
          },
          "$ref": "#/$defs/LDAPAugmenterConfig",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "plain"
            }
          },
          "$ref": "#/$defs/PlainAugmenterConfig",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "plain_advanced"
            }
          },
          "$ref": "#/$defs/PlainAdvancedAugmenterConfig",
          "required": [
            "type"
          ]
        }
      ]
    },
    "AuthConfig": {
      "description": "Configuration for the authentication timeout.\nThis is used for select_ok operations in the auth module,\nand we kill ongoing futures if they take too long.\n\nNote:\n- The attribute `#[serde(default = \"default_timeout_in_ms\")]` ensures that if\n  the `timeout_in_ms` key is missing during deserialization, it gets set to 5000.\n- However, when the entire auth section is omitted, Serde calls `AuthConfig::default()`.\n  Therefore, we manually implement Default for AuthConfig so that AuthConfig::default()\n  returns a timeout of 5000 instead of the primitive default (0).",
      "type": "object",
      "properties": {
        "timeout_in_ms": {
          "type": "integer",
          "format": "uint64",
          "default": 5000,
          "minimum": 0
        }
      }
    },
    "ConfigV1": {
      "type": "object",
      "properties": {
        "augmenters": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/AugmenterConfig"
          }
        },
        "auth": {
          "$ref": "#/$defs/AuthConfig",
          "default": {
            "timeout_in_ms": 5000
          }
        },
        "bind_address": {
          "type": "string"
        },
        "include_legacy_headers": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "jwt": {
          "$ref": "#/$defs/JWTConfig"
        },
        "logging": {
          "$ref": "#/$defs/LoggingConfig"
        },
        "providers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProviderConfig"
          }
        }
      },
      "required": [
        "providers",
        "bind_address",
        "jwt",
        "logging"
      ]
    },
    "ConfigV2": {
      "type": "object",
      "properties": {
        "augmenters": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/AugmenterConfig"
          }
        },
        "auth": {
          "$ref": "#/$defs/AuthConfig",
          "default": {
            "timeout_in_ms": 5000
          }
        },
        "include_legacy_headers": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "jwt": {
          "$ref": "#/$defs/JWTConfig"
        },
        "logging": {
          "$ref": "#/$defs/LoggingConfig"
        },
        "metrics": {
          "$ref": "#/$defs/MetricsConfig",
          "default": {
            "enabled": true,
            "port": 9090
          }
        },
        "providers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProviderConfig"
          }
        },
        "server": {
          "$ref": "#/$defs/ServerConfig"
        }
      },
      "required": [
        "providers",
        "server",
        "jwt",
        "logging"
      ]
    },
    "EFASApiProviderConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "required": [
        "uri",
        "name",
        "realm"
      ]
    },
    "EcmwfApiProviderConfig": {
      "description": "The config needed for the ECMWF API provider (who-am-i endpoint).",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "required": [
        "uri",
        "realm",
        "name"
      ]
    },
    "EcmwfTokenGeneratorProviderConfig": {
      "description": "Config for an ECMWF Token Generator provider that validates tokens through the token generator API.",
      "type": "object",
      "properties": {
        "cert_uri": {
          "type": "string"
        },
        "client_id": {
          "type": "string"
        },
        "client_secret": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        },
        "token_generator_url": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "cert_uri",
        "client_id",
        "client_secret",
        "token_generator_url",
        "realm"
      ]
    },
    "JWTAuthConfig": {
      "description": "JWT config structure for external usage",
      "type": "object",
      "properties": {
        "cert_uri": {
          "type": "string"
        },
        "iam_realm": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        }
      },
      "required": [
        "cert_uri",
        "realm",
        "name",
        "iam_realm"
      ]
    },
    "JWTConfig": {
      "description": "A simple definition for JWT usage in tokens.",
      "type": "object",
      "properties": {
        "aud": {
          "type": [
            "string",
            "null"
          ]
        },
        "exp": {
          "type": "integer",
          "format": "int64"
        },
        "iss": {
          "type": "string"
        },
        "secret": {
          "type": "string"
        }
      },
      "required": [
        "iss",
        "exp",
        "secret"
      ]
    },
    "LDAPAugmenterConfig": {
      "description": "Configuration required to connect to LDAP and fetch user roles.",
      "type": "object",
      "properties": {
        "bind_dn": {
          "type": [
            "string",
            "null"
          ]
        },
        "filter": {
          "type": [
            "string",
            "null"
          ]
        },
        "filters": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "ldap_password": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        },
        "search_base": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "realm",
        "uri",
        "search_base",
        "ldap_password"
      ]
    },
    "LoggingConfig": {
      "description": "LoggingConfig controls how we initialize tracing/logging.",
      "type": "object",
      "properties": {
        "format": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "service_name": {
          "type": "string",
          "default": "authotron"
        },
        "service_version": {
          "type": "string",
          "default": "0.3.7"
        }
      },
      "required": [
        "level",
        "format"
      ]
    },
    "MetricsConfig": {
      "description": "Controls the dedicated metrics/health server on a separate port.",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "default": 9090,
          "maximum": 65535,
          "minimum": 0
        }
      }
    },
    "OpenIDOfflineProviderConfig": {
      "description": "Config for an OpenID provider that also supports offline tokens.",
      "type": "object",
      "properties": {
        "cert_uri": {
          "type": "string"
        },
        "iam_url": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "private_client_id": {
          "type": "string"
        },
        "private_client_secret": {
          "type": "string"
        },
        "public_client_id": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "cert_uri",
        "public_client_id",
        "private_client_id",
        "private_client_secret",
        "iam_url",
        "realm"
      ]
    },
    "PlainAdvancedAugmenterAugment": {
      "type": "object",
      "properties": {
        "attributes": {
          "description": "Attributes to upsert (overwrite existing keys).",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "roles": {
          "description": "Roles to append (deduped).",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PlainAdvancedAugmenterConfig": {
      "description": "PlainAdvancedAugmenterConfig defines matching and augmentation rules.",
      "type": "object",
      "properties": {
        "augment": {
          "$ref": "#/$defs/PlainAdvancedAugmenterAugment"
        },
        "match": {
          "$ref": "#/$defs/PlainAdvancedAugmenterMatcher"
        },
        "name": {
          "type": "string"
        },
        "realm": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "realm",
        "match",
        "augment"
      ]
    },
    "PlainAdvancedAugmenterMatcher": {
      "type": "object",
      "properties": {
        "role": {
          "description": "Existing roles that trigger augmentation.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "username": {
          "description": "Users whose names trigger augmentation.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "PlainAugmenterConfig": {
      "description": "PlainAugmenterConfig defines the data for additional roles.",
      "type": "object",
      "properties": {
        "name": {
          "description": "A friendly name for logs.",
          "type": "string"
        },
        "realm": {
          "description": "The realm associated with this provider.",
          "type": "string"
        },
        "roles": {
          "description": "A list of roles and users.",
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "required": [
        "name",
        "realm",
        "roles"
      ]
    },
    "PlainAuthConfig": {
      "description": "PlainAuthConfig defines the data for Basic authentication.",
      "type": "object",
      "properties": {
        "name": {
          "description": "A friendly name for logs.",
          "type": "string"
        },
        "realm": {
          "description": "The realm associated with this provider.",
          "type": "string"
        },
        "users": {
          "description": "A list of username/password pairs.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/PlainUserEntry"
          }
        }
      },
      "required": [
        "name",
        "realm",
        "users"
      ]
    },
    "PlainUserEntry": {
      "description": "Represents a single user entry (username + password).",
      "type": "object",
      "properties": {
        "password": {
          "type": "string"
        },
        "roles": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "username": {
          "type": "string"
        }
      },
      "required": [
        "username",
        "password"
      ]
    },
    "ProviderConfig": {
      "description": "Configuration options for each authentication provider.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ecmwf-api"
            }
          },
          "$ref": "#/$defs/EcmwfApiProviderConfig",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ecmwf-token-generator"
            }
          },
          "$ref": "#/$defs/EcmwfTokenGeneratorProviderConfig",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "efas-api"
            }
          },
          "$ref": "#/$defs/EFASApiProviderConfig",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "jwt"
            }
          },
          "$ref": "#/$defs/JWTAuthConfig",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "openid-offline"
            }
          },
          "$ref": "#/$defs/OpenIDOfflineProviderConfig",
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "plain"
            }
          },
          "$ref": "#/$defs/PlainAuthConfig",
          "required": [
            "type"
          ]
        }
      ]
    },
    "ServerConfig": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string",
          "default": "0.0.0.0"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "port"
      ]
    }
  }
}
